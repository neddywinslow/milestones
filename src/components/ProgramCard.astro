---
interface Props {
  title: string;
  description: string;
  ages: string;
  href: string;
  imageAlt?: string;
  color?: "navy" | "sky" | "red";
}

const { title, description, ages, href, color = "sky" } = Astro.props;

const colorClasses = {
  navy: "text-brand-navy",
  sky: "text-brand-sky",
  red: "text-brand-red",
};
---
<a href={href} class="card group relative overflow-hidden flex flex-col items-start block transition-shadow hover:shadow-lg hover:border-brand-sky/30">
  <div class="mb-6 w-full aspect-[4/3] bg-surface-mist rounded-2xl overflow-hidden relative shadow-inner">
    <div class="absolute inset-0 bg-gradient-to-tr from-brand-navy/20 to-transparent z-10"></div>
    <!-- Program Image -->
    <img src={`/assets/${title.toLowerCase().includes('early') ? 'early-childhood.png' : title.toLowerCase().includes('kindergarten') ? 'kindergarten.png' : title.toLowerCase().includes('school') ? 'school-age.png' : title.toLowerCase().includes('summer') ? 'summer-camps-8yo.png' : 'hero.png'}`} alt={`${title} at Milestones`} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" />
  </div>
  
  <div class="flex items-center gap-2 mb-3">
    <span class={`text-xs font-semibold uppercase tracking-wider ${colorClasses[color]}`}>Ages: {ages}</span>
  </div>
  
  <h3 class="text-xl font-heading font-semibold text-brand-navy mb-2 group-hover:text-brand-red transition-colors">
    {title}
  </h3>
  
  <p class="text-text-slate text-sm flex-grow mb-6">
    {description}
  </p>
  
  <div class="mt-auto inline-flex items-center text-sm font-semibold text-brand-sky group-hover:text-brand-red transition-colors">
    Learn More 
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
    </svg>
  </div>
</a>
