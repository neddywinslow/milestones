---
import MainLayout from './MainLayout.astro';

const { frontmatter } = Astro.props;
---
<MainLayout title={frontmatter.title} description={frontmatter.summary}>
  <article class="max-w-[800px] mx-auto px-4 md:px-6 py-20">
    <header class="mb-12 text-center">
      {frontmatter.date && (
        <time class="text-brand-sky font-semibold tracking-widest uppercase mb-4 block">
          {new Date(frontmatter.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </time>
      )}
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-brand-navy mb-6">
        {frontmatter.title}
      </h1>
      {frontmatter.summary && (
        <p class="text-lg text-text-slate max-w-2xl mx-auto">
          {frontmatter.summary}
        </p>
      )}
    </header>
    
    <div class="prose prose-lg prose-headings:font-heading prose-headings:text-brand-navy prose-a:text-brand-sky hover:prose-a:text-brand-red max-w-none">
      <slot />
    </div>
  </article>
</MainLayout>
