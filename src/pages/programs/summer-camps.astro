---
import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout title="Summer Camps">
  <section class="py-20 bg-surface-sand relative overflow-hidden">
    <!-- Summer Image Background Layer -->
    <div class="absolute inset-0 z-0">
      <img src="/assets/summer-camps.png" alt="Children playing actively outside on a warm sunny day" class="w-full h-full object-cover opacity-30 mix-blend-multiply" />
      <div class="absolute inset-0 bg-gradient-to-t from-surface-sand via-surface-sand/80 to-transparent"></div>
    </div>
    <div class="max-w-[1000px] mx-auto px-4 md:px-6 relative z-10 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white shadow-sm border border-brand-navy/10 text-xs font-semibold text-brand-navy uppercase tracking-wide mb-6">
        Ages K3 - 7th Grade
      </div>
      <img src="/assets/camp-m.png" alt="Camp M Logo" class="mx-auto h-24 md:h-32 mb-6" />
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-brand-navy mb-6 drop-shadow-sm">Summer Camps</h1>
      <p class="text-xl text-text-slate max-w-2xl mx-auto font-medium">
        Exciting, action-packed summer adventures tailored to different age groups and interests under the Camp M umbrella.
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-[1000px] mx-auto px-4 md:px-6">
      
      <div class="bg-brand-sky/10 border border-brand-sky/20 rounded-2xl p-6 md:p-8 mb-16 text-center max-w-3xl mx-auto flex flex-col items-center">
         <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-brand-sky mb-4">
           <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
         </svg>
         <h2 class="font-heading font-bold text-2xl text-brand-navy mb-2">Summer Information Packets</h2>
         <p class="text-text-slate mb-6">Download the complete guides for dates, rates, and policies.</p>
         <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
            <a href="/assets/CAMPMINFO.pdf" target="_blank" rel="noopener noreferrer" class="btn-primary no-underline w-full sm:w-auto">Camp M Info (PDF)</a>
            <a href="/assets/SUMMINFO.pdf" target="_blank" rel="noopener noreferrer" class="btn-secondary no-underline w-full sm:w-auto">Summer M Info (PDF)</a>
         </div>
      </div>

      <div class="prose prose-lg prose-headings:font-heading prose-headings:text-brand-navy max-w-none text-text-ink leading-relaxed mb-16">
        <p class="text-center text-xl max-w-3xl mx-auto">
          When school is out, the fun begins! Milestones offers a variety of engaging summer camps that keep children active, learning, and socializing. Explore our 6 distinct <strong>Camp M</strong> programs designed for every stage of development.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        <!-- Little Explorers -->
        <div class="card bg-surface-sand/30 border-surface-mist flex flex-col items-center text-center">
          <div class="h-24 flex items-center justify-center mb-6 w-full bg-white rounded-xl p-4 shadow-sm">
             <img src="/assets/little-explorers.png" alt="Little Explorers Logo" class="max-h-16 object-contain" />
          </div>
          <h3 class="text-2xl font-bold font-heading text-brand-navy mb-2">Little Explorers</h3>
          <p class="text-brand-sky font-semibold tracking-wide uppercase text-sm mb-4">Serving K3 Children</p>
          <p class="text-text-slate text-base">Perfect for our youngest campers, featuring sensory play, arts and crafts, and outdoor discovery in a safe, nurturing environment.</p>
        </div>

        <!-- Kid Crew -->
        <div class="card bg-surface-sand/30 border-surface-mist flex flex-col items-center text-center">
          <div class="h-24 flex items-center justify-center mb-6 w-full bg-white rounded-xl p-4 shadow-sm">
             <img src="/assets/kid-crew.png" alt="Kid Crew Logo" class="max-h-16 object-contain" />
          </div>
          <h3 class="text-2xl font-bold font-heading text-brand-navy mb-2">Kid Crew</h3>
          <p class="text-brand-sky font-semibold tracking-wide uppercase text-sm mb-4">Serving K4 & K5 Children</p>
          <p class="text-text-slate text-base">Blending organized games, weekly themes, and creative projects to keep early elementary students engaged all summer long.</p>
        </div>

        <!-- Jet Set -->
        <div class="card bg-surface-sand/30 border-surface-mist flex flex-col items-center text-center">
          <div class="h-24 flex items-center justify-center mb-6 w-full bg-white rounded-xl p-4 shadow-sm">
             <img src="/assets/jet-set.png" alt="Jet Set Logo" class="max-h-16 object-contain" />
          </div>
          <h3 class="text-2xl font-bold font-heading text-brand-navy mb-2">Jet Set</h3>
          <p class="text-brand-sky font-semibold tracking-wide uppercase text-sm mb-4">Serving 1st & 2nd Grade</p>
          <p class="text-text-slate text-base">Ready for liftoff! Campers explore new hobbies, enjoy exciting field trips, and build lasting friendships.</p>
        </div>

        <!-- Action Pack -->
        <div class="card bg-surface-sand/30 border-surface-mist flex flex-col items-center text-center">
          <div class="h-24 flex items-center justify-center mb-6 w-full bg-white rounded-xl p-2 shadow-sm">
             <img src="/assets/action-pack.jpg" alt="Action Pack Logo" class="max-h-20 object-contain rounded-md" />
          </div>
          <h3 class="text-2xl font-bold font-heading text-brand-navy mb-2">Action Pack</h3>
          <p class="text-brand-sky font-semibold tracking-wide uppercase text-sm mb-4">Serving 3rd & 4th Grade</p>
          <p class="text-text-slate text-base">Designed for older children, featuring introductory leadership activities, bigger collaborative projects, and dynamic challenges.</p>
        </div>

        <!-- Camp M2 -->
        <div class="card bg-surface-sand/30 border-surface-mist flex flex-col items-center text-center md:col-span-2 lg:col-span-1">
          <div class="h-24 flex items-center justify-center mb-6 w-full bg-white rounded-xl p-2 shadow-sm">
             <img src="/assets/m2-logo.jpg" alt="Camp M2 Logo" class="max-h-20 object-contain rounded-md" />
          </div>
          <h3 class="text-2xl font-bold font-heading text-brand-navy mb-2">Camp M2</h3>
          <p class="text-brand-sky font-semibold tracking-wide uppercase text-sm mb-4">Serving 5th, 6th & 7th Grade</p>
          <p class="text-text-slate text-base">An engaging independence-focused camp for young teens, offering advanced activities, specialized excursions, and team building.</p>
        </div>

        <!-- Summer M -->
        <div class="card border-brand-red/30 bg-brand-red/5 flex flex-col items-center text-center md:col-span-2 lg:col-span-1 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-16 h-16 bg-brand-red rounded-bl-full opacity-10"></div>
          <div class="h-24 flex items-center justify-center mb-6 w-full bg-white rounded-xl p-4 shadow-sm border border-brand-red/10">
             <img src="/assets/summer-m.png" alt="Summer M Logo" class="max-h-16 object-contain" />
          </div>
          <h3 class="text-2xl font-bold font-heading text-brand-red mb-2">Summer M Day Camps</h3>
          <p class="text-brand-sky font-semibold tracking-wide uppercase text-sm mb-2">Serving K4 - 7th Grade</p>
          <p class="text-brand-navy text-sm font-medium mb-4 italic">Operates at Indian Hill School in River Hills</p>
          <p class="text-text-slate text-base">A specialized community-based summer camp experience operating out of Indian Hill with complete outdoor and indoor recreation access.</p>
        </div>
      </div>

      <div class="mt-16 text-center">
        <a href="/parents/enrollment" class="btn-primary px-8 text-lg inline-flex">Summer Enrollment Details</a>
      </div>
    </div>
  </section>
</MainLayout>
