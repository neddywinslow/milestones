---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Contact Us">
  <section class="py-20 bg-brand-navy border-t-8 border-brand-red">
    <div class="max-w-[800px] mx-auto px-4 md:px-6 text-center text-white">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-6">Contact Us</h1>
      <p class="text-xl text-white/80 max-w-2xl mx-auto leading-relaxed">
        We're here to answer any questions you may have about our programs, enrollment, or community.
      </p>
    </div>
  </section>

  <section class="py-20 bg-surface-sand">
    <div class="max-w-[1000px] mx-auto px-4 md:px-6">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="card bg-white p-8 lg:p-12">
          <h2 class="text-2xl font-heading font-bold text-brand-navy mb-6">Administrative Office</h2>
          
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="text-brand-sky mt-1 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                   <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                   <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <div>
                <strong class="block text-brand-navy mb-1">Mailing Address</strong>
                <address class="not-italic text-text-slate">
                  2214 East Capitol Drive<br/>Shorewood, WI 53211
                </address>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="text-brand-sky mt-1 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.48-4.18-7.076-7.076l1.293-.97c.362-.271.527-.733.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
              </div>
              <div>
                <strong class="block text-brand-navy mb-1">Phone & Fax</strong>
                <p class="text-text-slate"><a href="tel:414-964-5545" class="hover:text-brand-red">414-964-5545</a></p>
                <p class="text-text-slate text-sm">Fax: 414-964-5609</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="text-brand-sky mt-1 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <strong class="block text-brand-navy mb-1">Email</strong>
                <p class="text-text-slate"><a href="mailto:info@milestonesprograms.org" class="hover:text-brand-red">info@milestonesprograms.org</a></p>
              </div>
            </div>
          </div>
        </div>

        <div class="flex flex-col justify-center">
          <h2 class="text-3xl font-heading font-bold text-brand-navy mb-6">Send Us a Message</h2>
          <p class="text-text-slate mb-8 leading-relaxed">
            Please use the contact information provided or email us directly at <a href="mailto:info@milestonesprograms.org" class="text-brand-sky font-semibold hover:text-brand-red">info@milestonesprograms.org</a>. We strive to reply to all inquiries within 1-2 business days.
          </p>
          <div class="bg-brand-navy p-6 rounded-2xl text-white">
            <h3 class="font-heading font-semibold text-xl mb-2">Looking to Enroll?</h3>
            <p class="text-sm text-white/80 mb-4">You can find most answers on our Enrollment page.</p>
            <a href="/parents/enrollment" class="inline-block px-4 py-2 bg-white text-brand-navy rounded-lg text-sm font-semibold hover:bg-surface-sand transition-colors">View Enrollment</a>
          </div>
        </div>
      </div>

    </div>
  </section>
</MainLayout>
