---
import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout title="Careers">
  <section class="py-20 bg-surface-sand">
    <div class="max-w-[800px] mx-auto px-4 md:px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-brand-navy mb-6">Careers at Milestones</h1>
      <p class="text-xl text-text-slate leading-relaxed">
        Join our passionate team of educators dedicated to providing the highest quality care and learning environments for children.
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-[1000px] mx-auto px-4 md:px-6">
      <div class="prose prose-lg prose-headings:font-heading prose-headings:text-brand-navy max-w-none text-text-ink leading-relaxed">
        <p>
          At Milestones, we recognize that our teachers are our most valuable resource. We strive to create a collaborative, supportive, and professional atmosphere where educators can grow in their careers.
        </p>

        <h2>Why Work With Us?</h2>
        <ul>
          <li><strong>Professional Environment:</strong> Work alongside experienced educators who are leaders in the Early Childhood and School Age fields.</li>
          <li><strong>Impact:</strong> Make a meaningful difference in the lives of children and families in the Milwaukee area.</li>
          <li><strong>Growth:</strong> We support ongoing professional development and training.</li>
        </ul>

        <div class="bg-surface-sand border border-surface-mist p-8 rounded-2xl my-12 text-center">
          <h3 class="mt-0">Current Openings</h3>
          <p class="text-base text-text-slate mb-6">We are currently accepting applications for Teachers, Assistant Teachers, and Camp Counselors with open availability.</p>
          <p class="font-semibold text-brand-navy mb-0">Please send your resume and a cover letter to:</p>
          <a href="mailto:info@milestonesprograms.org" class="text-brand-sky hover:text-brand-red text-lg">info@milestonesprograms.org</a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
