---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Donate">
  <section class="py-20 bg-brand-navy border-t-8 border-brand-red">
    <div class="max-w-[800px] mx-auto px-4 md:px-6 text-center text-white">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-6">Support Our Mission</h1>
      <p class="text-xl text-white/80 max-w-2xl mx-auto leading-relaxed mb-4">
        Milestones Programs for Children relies on generous support to continue providing the highest quality care and educational opportunities to children across our community.
      </p>
      <p class="text-sm text-brand-sky font-semibold bg-brand-navy/50 inline-block px-4 py-2 rounded-full border border-brand-sky/30">
        Milestones is a registered 501(c)(3) nonprofit organization. Your gift is tax-deductible to the extent allowed by law.
      </p>
    </div>
  </section>

  <section class="py-20 bg-surface-sand">
    <div class="max-w-[1000px] mx-auto px-4 md:px-6">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        <!-- Direct Donation -->
        <div class="card bg-white p-8 lg:p-12 text-center flex flex-col items-center">
          <div class="w-16 h-16 bg-brand-navy rounded-2xl flex items-center justify-center text-white mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.315 48.315 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z" />
            </svg>
          </div>
          <h2 class="text-2xl font-heading font-bold text-brand-navy mb-4">Direct Donation</h2>
          <p class="text-text-slate mb-8 flex-grow">
            Make a one-time or recurring gift directly to Milestones to seamlessly support our everyday programs and scholarship opportunities.
          </p>
          
          <!-- Donation Placeholder -->
          <div class="w-full bg-surface-sand p-6 rounded-2xl border border-surface-mist flex flex-col items-center">
             <p class="text-brand-navy font-semibold mb-2">Donation Form Placehoder</p>
             <div class="flex gap-2">
                <button class="px-4 py-2 border border-brand-sky text-brand-navy bg-white rounded-lg hover:bg-brand-sky hover:text-white transition-colors">$25</button>
                <button class="px-4 py-2 border border-brand-sky text-brand-navy bg-white rounded-lg hover:bg-brand-sky hover:text-white transition-colors">$50</button>
                <button class="px-4 py-2 border border-brand-sky text-brand-navy bg-white rounded-lg hover:bg-brand-sky hover:text-white transition-colors">$100</button>
             </div>
             <button class="btn-primary w-full mt-4 cursor-not-allowed opacity-80">Donate Now</button>
          </div>
        </div>

        <!-- United Way -->
        <a href="/united-way-giving" class="card bg-white border-2 border-transparent hover:border-brand-sky/30 transition-all group lg:p-12 text-center flex flex-col items-center">
          <div class="w-16 h-16 bg-brand-red rounded-2xl flex items-center justify-center text-white mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
            </svg>
          </div>
          <h2 class="text-2xl font-heading font-bold text-brand-navy mb-4 group-hover:text-brand-red transition-colors">United Way Giving</h2>
          <p class="text-text-slate mb-8 flex-grow">
            Designate your United Way gift to Milestones Programs for Children via the Donor Choice / write-in program. 
          </p>
          <div class="btn-secondary w-full group-hover:bg-brand-red group-hover:text-white group-hover:border-transparent mt-auto">
            View Instructions
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 ml-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </div>
        </a>
      </div>

    </div>
  </section>
</MainLayout>
