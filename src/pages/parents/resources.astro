---
import MainLayout from '../../layouts/MainLayout.astro';
import resources from '../../data/resources.json';
---
<MainLayout title="Parent Resources">
  <section class="py-20 bg-surface-sand">
    <div class="max-w-[1000px] mx-auto px-4 md:px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-brand-navy mb-6">Parent Resources</h1>
      <p class="text-xl text-text-slate leading-relaxed">
        Important documents, handbooks, and policy guides for Milestones families.
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-[1000px] mx-auto px-4 md:px-6">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {resources.map((resource) => (
          <a href={resource.url} target="_blank" rel="noopener noreferrer" class="card hover:border-brand-sky/40 hover:shadow-md transition-all group flex flex-col h-full bg-surface-sand/30">
            <div class="flex items-start gap-4 mb-4">
              <div class="text-brand-red mt-1 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                </svg>
              </div>
              <div>
                <h2 class="text-xl font-heading font-semibold text-brand-navy mb-2 group-hover:text-brand-sky transition-colors">{resource.title}</h2>
                <p class="text-text-slate text-sm">{resource.description}</p>
              </div>
            </div>
            <div class="mt-auto pt-4 flex items-center text-sm font-semibold text-brand-sky group-hover:text-brand-red transition-colors">
              Download PDF
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 ml-1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>
</MainLayout>
