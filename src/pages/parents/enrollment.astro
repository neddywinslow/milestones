---
import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout title="Enrollment">
  <section class="py-20 bg-brand-navy border-t-8 border-brand-sky">
    <div class="max-w-[800px] mx-auto px-4 md:px-6 text-center text-white">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-6">Enrollment & Registration</h1>
      <p class="text-xl text-white/80 max-w-2xl mx-auto leading-relaxed">
        Join the Milestones family. We process all enrollments securely through our online Family Portal system.
      </p>
    </div>
  </section>

  <section class="py-20 bg-surface-sand">
    <div class="max-w-[1000px] mx-auto px-4 md:px-6">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        <!-- New Families -->
        <div class="card bg-white p-8 lg:p-12 text-center flex flex-col items-center">
          <h2 class="text-2xl font-heading font-bold text-brand-navy mb-4">New Families</h2>
          <p class="text-text-slate mb-8 flex-grow">
            If you are new to Milestones, you must first create an account and submit your initial registration information.
          </p>
          <a href="https://www.schoolcareworks.com/reg_milestones/start_registration.jsp" target="_blank" rel="noopener noreferrer" class="btn-primary w-full">
            Start New Registration
          </a>
        </div>

        <!-- Existing Families -->
        <div class="card bg-white p-8 lg:p-12 text-center flex flex-col items-center">
          <h2 class="text-2xl font-heading font-bold text-brand-navy mb-4">Existing Families</h2>
          <p class="text-text-slate mb-8 flex-grow">
            Current families should use the Family Portal to register for upcoming sessions, manage tuition, and update information.
          </p>
          <a href="https://connect.schoolcareworks.com/milestones_login.jsp" target="_blank" rel="noopener noreferrer" class="btn-secondary w-full">
            Log Into Family Portal
          </a>
        </div>
      </div>

      <div class="mt-16 text-center max-w-2xl mx-auto">
        <h3 class="font-heading font-semibold text-brand-navy text-xl mb-4">Need Assistance?</h3>
        <p class="text-text-slate mb-6">
          If you have questions about the curriculum, waiting lists, or the registration process itself, we're here to help.
        </p>
        <a href="/contact" class="text-brand-sky font-semibold hover:text-brand-red transition-colors">Contact Our Administrative Office</a>
      </div>

    </div>
  </section>
</MainLayout>
